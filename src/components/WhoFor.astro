---
interface Props {
  lang: "en" | "es";
}

import { t } from "../i18n";
import SectionHeading from "./SectionHeading.astro";

const { lang } = Astro.props;

const cards = [
  { titleKey: "home.whofor.card1.title", bodyKey: "home.whofor.card1.body" },
  { titleKey: "home.whofor.card2.title", bodyKey: "home.whofor.card2.body" },
  { titleKey: "home.whofor.card3.title", bodyKey: "home.whofor.card3.body" },
] as const;

const icons = [
  // SaaS Engineering Teams — code/brackets icon
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  // Team Leads & CTOs — users icon
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  // Existing Systems — layers/stack icon
  `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>`,
];
---

<section class="section-padding">
  <div class="mx-auto max-w-4xl px-4">
    <SectionHeading text={t(lang, "home.whofor.heading")} />
    <p class="animate-fade-up mt-4 max-w-2xl text-lg leading-relaxed text-(--color-text-secondary)">
      {t(lang, "home.whofor.body")}
    </p>

    <div class="mt-10 grid gap-6 sm:grid-cols-3">
      {cards.map((card, i) => (
        <div class:list={["glass-card rounded-lg p-6", i === 0 ? "animate-fade-up" : i === 1 ? "animate-fade-up-delay-1" : "animate-fade-up-delay-2"]}>
          <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-md bg-(--color-accent)/10 text-(--color-accent)">
            <Fragment set:html={icons[i]} />
          </div>
          <h3 class="font-semibold text-(--color-text-primary)">{t(lang, card.titleKey)}</h3>
          <p class="mt-2 text-sm leading-relaxed text-(--color-text-secondary)">
            {t(lang, card.bodyKey)}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
