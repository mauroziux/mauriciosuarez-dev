---
interface Props {
  lang: "en" | "es";
}

import { t, getRoute } from "../i18n";

const { lang } = Astro.props;
---

<section class="section-padding relative bg-dot-grid">
  <div class="mx-auto max-w-4xl px-4">
    <div class="max-w-2xl">
      <p class="animate-fade-up text-sm font-medium tracking-widest text-(--color-accent) uppercase">
        {t(lang, "home.hero.eyebrow")}
      </p>
      <h1 class="animate-fade-up-delay-1 mt-4 text-4xl font-bold leading-tight tracking-tight text-(--color-text-primary) sm:text-5xl lg:text-6xl">
        <span class="text-gradient">{t(lang, "home.hero.title")}</span>
      </h1>
      <p class="animate-fade-up-delay-2 mt-6 text-lg leading-relaxed text-(--color-text-secondary) sm:text-xl">
        {t(lang, "home.hero.tagline")}
      </p>
      <p class="animate-fade-up-delay-3 mt-4 text-base font-medium leading-relaxed text-(--color-text-tertiary) sm:text-lg">
        {t(lang, "home.hero.tone")}
      </p>
      <div class="animate-fade-up-delay-3 mt-8 flex flex-wrap gap-3">
        <a href={getRoute(lang, "contact")} class="btn-primary">
          {t(lang, "home.hero.cta.audit")}
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
        <a href={getRoute(lang, "work")} class="btn-secondary">
          {t(lang, "home.hero.cta.work")}
        </a>
      </div>
    </div>
  </div>

  <!-- Subtle bottom gradient fade -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-(--color-bg-primary) to-transparent"></div>
</section>
