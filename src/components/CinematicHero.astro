---
interface Props {
  lang: "en" | "es";
}

import { t, getRoute } from "../i18n";

const { lang } = Astro.props;
---

<section class="film-grain relative min-h-screen overflow-hidden bg-(--color-bg-primary)">
  <!-- Line grid background -->
  <div class="bg-line-grid pointer-events-none absolute inset-0"></div>

  <!-- Hero glow -->
  <div class="pointer-events-none absolute -top-[10%] -left-[10%] h-[60%] w-[50%]" aria-hidden="true">
    <div class="h-full w-full" style="background: radial-gradient(ellipse at center, rgba(196, 30, 58, 0.06) 0%, transparent 70%);"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-5xl px-4 pt-20 pb-16 sm:pt-28 md:pt-36">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: Text content -->
      <div>
        <p class="reveal reveal-delay-1 text-sm font-medium uppercase tracking-widest text-(--color-accent)">
          {t(lang, "home.hero.eyebrow")}
        </p>
        <h1 class="reveal reveal-delay-2 mt-5 text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          <span class="text-(--color-text-primary)">{t(lang, "home.hero.title.lead")}</span><span class="text-metallic">{t(lang, "home.hero.title.highlight")}</span><span class="text-(--color-text-primary)">{t(lang, "home.hero.title.tail")}</span>
        </h1>
        <p class="reveal reveal-delay-3 mt-6 text-lg leading-relaxed text-(--color-text-secondary) sm:text-xl">
          {t(lang, "home.hero.tagline")}
        </p>
        <p class="reveal reveal-delay-4 mt-4 text-base font-medium leading-relaxed text-(--color-text-tertiary) sm:text-lg">
          {t(lang, "home.hero.tone")}
        </p>
        <div class="reveal reveal-delay-5 mt-8 flex flex-wrap gap-3">
          <a href={getRoute(lang, "contact")} class="btn-tactile">
            {t(lang, "home.hero.cta.audit")}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href={getRoute(lang, "work")} class="btn-secondary">
            {t(lang, "home.hero.cta.work")}
          </a>
        </div>
      </div>

      <!-- Right: Device mockup -->
      <div class="cinematic-card reveal reveal-delay-2 relative p-6 sm:p-8">
        <!-- iPhone mockup -->
        <div class="iphone-frame relative mx-auto aspect-[9/19] max-w-[280px] overflow-hidden p-[6px]">
          <div class="iphone-screen relative h-full w-full overflow-hidden p-4">
            <!-- Dynamic Island -->
            <div class="mx-auto mb-4 h-[22px] w-[90px] rounded-full bg-black"></div>

            <!-- App UI skeleton -->
            <div class="space-y-3">
              <!-- Status bar skeleton -->
              <div class="flex items-center justify-between">
                <div class="h-2 w-12 rounded bg-white/5"></div>
                <div class="h-2 w-8 rounded bg-white/5"></div>
              </div>

              <!-- Progress ring area -->
              <div class="flex items-center gap-3 rounded-xl bg-white/[0.03] p-3">
                <svg class="h-10 w-10 shrink-0" viewBox="0 0 40 40">
                  <circle cx="20" cy="20" r="16" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="3"></circle>
                  <circle cx="20" cy="20" r="16" fill="none" stroke="var(--color-accent)" stroke-width="3" stroke-dasharray="75 100" stroke-linecap="round" transform="rotate(-90 20 20)"></circle>
                </svg>
                <div class="space-y-1.5">
                  <div class="h-2 w-20 rounded bg-white/10"></div>
                  <div class="h-1.5 w-14 rounded bg-white/5"></div>
                </div>
              </div>

              <!-- Task cards -->
              <div class="space-y-2">
                <div class="flex items-center gap-2 rounded-lg bg-white/[0.03] p-2.5">
                  <div class="h-6 w-6 rounded-full bg-(--color-accent)/20"></div>
                  <div class="flex-1 space-y-1">
                    <div class="h-1.5 w-3/4 rounded bg-white/10"></div>
                    <div class="h-1 w-1/2 rounded bg-white/5"></div>
                  </div>
                  <div class="h-4 w-8 rounded bg-green-500/10"></div>
                </div>
                <div class="flex items-center gap-2 rounded-lg bg-white/[0.03] p-2.5">
                  <div class="h-6 w-6 rounded-full bg-(--color-accent-gold)/20"></div>
                  <div class="flex-1 space-y-1">
                    <div class="h-1.5 w-2/3 rounded bg-white/10"></div>
                    <div class="h-1 w-1/3 rounded bg-white/5"></div>
                  </div>
                  <div class="h-4 w-8 rounded bg-yellow-500/10"></div>
                </div>
                <div class="flex items-center gap-2 rounded-lg bg-white/[0.03] p-2.5">
                  <div class="h-6 w-6 rounded-full bg-blue-500/20"></div>
                  <div class="flex-1 space-y-1">
                    <div class="h-1.5 w-4/5 rounded bg-white/10"></div>
                    <div class="h-1 w-2/5 rounded bg-white/5"></div>
                  </div>
                  <div class="h-4 w-8 rounded bg-blue-500/10"></div>
                </div>
              </div>

              <!-- Avatar row -->
              <div class="mt-2 flex items-center gap-2">
                <div class="h-6 w-6 rounded-full bg-white/10"></div>
                <div class="h-1.5 w-16 rounded bg-white/5"></div>
              </div>
            </div>
          </div>

          <!-- Glare overlay -->
          <div class="iphone-glare pointer-events-none absolute inset-0"></div>
        </div>

        <!-- Floating badges -->
        <div class="floating-badge pointer-events-none absolute -right-4 top-8 hidden px-3 py-2 text-xs font-medium text-(--color-text-secondary) sm:block">
          <span class="text-green-400">●</span>&nbsp; {t(lang, "home.hero.badge.1")}
        </div>
        <div class="floating-badge pointer-events-none absolute -left-4 bottom-16 hidden px-3 py-2 text-xs font-medium text-(--color-text-secondary) sm:block">
          <span class="text-(--color-accent)">✓</span>&nbsp; {t(lang, "home.hero.badge.2")}
        </div>
        <div class="floating-badge pointer-events-none absolute -right-2 bottom-8 hidden px-3 py-2 text-xs font-medium text-(--color-text-secondary) sm:block">
          <span class="text-(--color-accent-gold)">⚡</span>&nbsp; {t(lang, "home.hero.badge.3")}
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom gradient fade -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-(--color-bg-primary) to-transparent"></div>
</section>

<script>
  // Mouse-follow lighting on cinematic card
  const card = document.querySelector('.cinematic-card');
  if (card) {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', `${e.clientX - rect.left}px`);
      card.style.setProperty('--mouse-y', `${e.clientY - rect.top}px`);
    });
  }

  // Scroll reveal via IntersectionObserver
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  reveals.forEach((el) => observer.observe(el));
</script>
