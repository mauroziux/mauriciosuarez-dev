---
interface Props {
  lang: "en" | "es";
}

import { t, getRoute } from "../i18n";
import SectionHeading from "./SectionHeading.astro";

const { lang } = Astro.props;
---

<section class="section-padding">
  <div class="mx-auto max-w-4xl px-4">
    <SectionHeading text={t(lang, "home.services.heading")} />
    <p class="animate-fade-up mt-3 max-w-lg text-(--color-text-secondary)">
      {t(lang, "home.services.subtitle")}
    </p>

    <div class="mt-10 grid gap-5 sm:grid-cols-2">
      <a href={getRoute(lang, "services")} class="animate-fade-up glass-card service-card rounded-lg p-6">
        <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-md bg-(--color-accent)/10 text-(--color-accent)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2z"/><path d="m3 3 3 3"/><path d="m21 3-3 3"/></svg>
        </div>
        <h3 class="font-semibold text-(--color-text-primary)">{t(lang, "home.services.audit.title")}</h3>
        <p class="mt-2 text-sm leading-relaxed text-(--color-text-secondary)">
          {t(lang, "home.services.audit.teaser")}
        </p>
      </a>

      <a href={getRoute(lang, "services")} class="animate-fade-up-delay-1 glass-card service-card rounded-lg p-6">
        <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-md bg-(--color-accent)/10 text-(--color-accent)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        </div>
        <h3 class="font-semibold text-(--color-text-primary)">{t(lang, "home.services.agents.title")}</h3>
        <p class="mt-2 text-sm leading-relaxed text-(--color-text-secondary)">
          {t(lang, "home.services.agents.teaser")}
        </p>
      </a>

      <a href={getRoute(lang, "services")} class="animate-fade-up glass-card service-card rounded-lg p-6">
        <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-md bg-(--color-accent)/10 text-(--color-accent)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
        </div>
        <h3 class="font-semibold text-(--color-text-primary)">{t(lang, "home.services.legacy.title")}</h3>
        <p class="mt-2 text-sm leading-relaxed text-(--color-text-secondary)">
          {t(lang, "home.services.legacy.teaser")}
        </p>
      </a>

      <a href={getRoute(lang, "services")} class="animate-fade-up-delay-1 glass-card service-card rounded-lg p-6">
        <div class="mb-3 inline-flex h-9 w-9 items-center justify-center rounded-md bg-(--color-accent)/10 text-(--color-accent)">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="font-semibold text-(--color-text-primary)">{t(lang, "home.services.devex.title")}</h3>
        <p class="mt-2 text-sm leading-relaxed text-(--color-text-secondary)">
          {t(lang, "home.services.devex.teaser")}
        </p>
      </a>
    </div>

    <div class="animate-fade-up-delay-2 mt-8">
      <a href={getRoute(lang, "services")} class="link-accent text-sm font-medium">
        {t(lang, "home.services.cta")}
      </a>
    </div>
  </div>
</section>
