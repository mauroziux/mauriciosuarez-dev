---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";
const lang = "es" as const;
---

<BaseLayout lang={lang} title={t(lang, "about.title")} description={t(lang, "meta.description.about")}>
  <div class="section-padding">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="text-3xl font-bold tracking-tight text-(--color-text-primary) sm:text-4xl">{t(lang, "about.title")}</h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-(--color-text-primary) font-medium">{t(lang, "about.intro")}</p>

      <div class="mt-10 glass-card max-w-2xl rounded-lg p-8">
        <p class="leading-relaxed text-(--color-text-secondary)">
          {t(lang, "about.description")}
        </p>
      </div>

      <div class="mt-10 max-w-2xl">
        <h2 class="text-xl font-semibold tracking-tight text-(--color-text-primary)">{t(lang, "about.background.title")}</h2>
        <p class="mt-3 leading-relaxed text-(--color-text-secondary)">
          {t(lang, "about.background.body")}
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
