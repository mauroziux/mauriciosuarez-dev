---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { t } from "../../i18n";

const lang = "en" as const;

const pillars = [
  { key: "writing.pillars.ai-eng", icon: "brain" },
  { key: "writing.pillars.devex", icon: "zap" },
  { key: "writing.pillars.arch", icon: "blocks" },
] as const;
---

<BaseLayout lang={lang} title={t(lang, "writing.title")} description={t(lang, "meta.description.writing")}>
  <div class="section-padding">
    <div class="mx-auto max-w-4xl px-4">
      <h1 class="animate-fade-up text-3xl font-bold tracking-tight text-(--color-text-primary) sm:text-4xl">
        {t(lang, "writing.title")}
      </h1>
      <p class="animate-fade-up-delay-1 mt-4 max-w-2xl text-lg leading-relaxed text-(--color-text-secondary)">
        {t(lang, "writing.subtitle")}
      </p>

      <!-- Writing pillars -->
      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        {pillars.map((pillar, i) => (
          <div class:list={[
            "glass-card rounded-lg p-6 text-center",
            i === 0 ? "animate-fade-up" : i === 1 ? "animate-fade-up-delay-1" : "animate-fade-up-delay-2",
          ]}>
            <div class="mx-auto mb-3 inline-flex h-10 w-10 items-center justify-center rounded-md bg-(--color-accent)/10 text-(--color-accent)">
              {pillar.icon === "brain" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>
              )}
              {pillar.icon === "zap" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              )}
              {pillar.icon === "blocks" && (
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/><rect width="7" height="7" x="3" y="3" rx="1"/></svg>
              )}
            </div>
            <h3 class="font-semibold text-(--color-text-primary)">{t(lang, pillar.key)}</h3>
          </div>
        ))}
      </div>

      <!-- Empty state -->
      <div class="animate-fade-up-delay-3 mt-16 text-center">
        <div class="mx-auto max-w-md glass-card rounded-lg p-8">
          <p class="text-(--color-text-secondary)">{t(lang, "writing.empty")}</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
